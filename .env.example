# Copy this file to .env for local development
# In Vercel, add these under Project Settings → Environment Variables

# Firebase Realtime Database URL (from Firebase Console → Project Settings)
VITE_FIREBASE_URL=https://YOUR-PROJECT-ID-default-rtdb.firebaseio.com

# --- Server-side only (never exposed to browser) ---
# Your Anthropic API key (from https://console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXX

# Your Firebase URL again — used server-side by the proxy
FIREBASE_URL=https://YOUR-PROJECT-ID-default-rtdb.firebaseio.com

# The URL of your deployed app (used for CORS)
# e.g. https://the-wager.vercel.app
ALLOWED_ORIGIN=https://your-app.vercel.app
